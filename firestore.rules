rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function profileFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'displayName', 'age', 'city', 'role', 'identity', 'interestedIn',
        'orientation', 'intent', 'termsAcceptedAt', 'termsVersion', 'updatedAt'
      ]);
    }

    match /members/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.isMember == false
        && request.resource.data.wallet == 1200
        && request.resource.data.callsUsed == 0;
      allow update: if isOwner(userId) && profileFieldsOnly();
      allow delete: if false;

      match /stripePayments/{paymentId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /giftsSent/{giftId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /giftsReceived/{giftId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    match /matchRequests/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /matches/{matchId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read, write: if false;
    }
  }
}
